{
  "api_name": "bing-webmaster-tools",
  "base_url": "https://ssl.bing.com/webmaster/api.svc/json",
  "description": "Bing Webmaster Tools API CLI — sites, sitemaps, URL \u0026 content submission, traffic \u0026 query stats, crawl control, links, keyword research, and per-site config, with a local store and offline search.",
  "mcp_ready": "full",
  "http_transport": "standard",
  "auth": {
    "type": "api_key",
    "header": "apikey",
    "in": "query",
    "env_vars": [
      "BING_WEBMASTER_API_KEY"
    ],
    "env_var_specs": [
      {
        "name": "BING_WEBMASTER_API_KEY",
        "kind": "per_call",
        "required": true,
        "sensitive": true,
        "inferred": true
      }
    ],
    "key_url": "https://www.bing.com/webmasters/"
  },
  "required_headers": [],
  "tools": [
    {
      "name": "block-urls_add",
      "description": "Block a URL or directory from Bing's index. Required: siteUrl, blockedUrl. Optional: entityType, requestType.",
      "method": "POST",
      "path": "/AddBlockedUrl",
      "params": [
        {
          "name": "siteUrl",
          "type": "string",
          "location": "body",
          "description": "Site URL",
          "required": true
        },
        {
          "name": "blockedUrl",
          "type": "string",
          "location": "body",
          "description": "URL or directory to block",
          "required": true
        },
        {
          "name": "entityType",
          "type": "string",
          "location": "body",
          "description": "Block scope: Page or Directory"
        },
        {
          "name": "requestType",
          "type": "string",
          "location": "body",
          "description": "Block type: FullRemoval or CacheRemoval"
        }
      ]
    },
    {
      "name": "block-urls_list",
      "description": "List URLs/directories blocked from Bing's index for a site. Required: siteUrl. Returns array of BlockedUrl.",
      "method": "GET",
      "path": "/GetBlockedUrls",
      "params": [
        {
          "name": "siteUrl",
          "type": "string",
          "location": "query",
          "description": "Site URL",
          "required": true
        }
      ]
    },
    {
      "name": "block-urls_remove",
      "description": "Unblock a previously blocked URL or directory. Required: siteUrl, blockedUrl. Optional: entityType, requestType.",
      "method": "POST",
      "path": "/RemoveBlockedUrl",
      "params": [
        {
          "name": "siteUrl",
          "type": "string",
          "location": "body",
          "description": "Site URL",
          "required": true
        },
        {
          "name": "blockedUrl",
          "type": "string",
          "location": "body",
          "description": "URL or directory to unblock",
          "required": true
        },
        {
          "name": "entityType",
          "type": "string",
          "location": "body",
          "description": "Block scope: Page or Directory"
        },
        {
          "name": "requestType",
          "type": "string",
          "location": "body",
          "description": "Block type: FullRemoval or CacheRemoval"
        }
      ]
    },
    {
      "name": "crawl_get-settings",
